# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI Services (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# AI Feature Kill-Switch
# Master switch for all AI features (lesson / exit-ticket / progress-check /
# worksheet generation and AI document upload). Disabled by default: gated AI
# routes return 404 and make NO external LLM/provider calls unless this is 'true'.
AI_FEATURES_ENABLED=false

# AI Privacy and Security (Optional)
# WARNING: These flags control storage of sensitive data including prompts and responses
# Only enable for debugging purposes in non-production environments
# Default is false (prompts and raw responses are NOT captured)
CAPTURE_FULL_PROMPTS=false  # Set to 'true' to capture full prompts (with PII redaction)
CAPTURE_AI_RAW=false        # Set to 'true' to capture raw AI responses (with PII redaction)

# Email Service (Optional)
# Resend powers the inbound email -> worksheet webhook only. That endpoint is
# DISABLED by default (EMAIL_WEBHOOK_ENABLED unset). Provider signature
# verification is NOT yet implemented and must be added before re-enabling
# (SPE-128); flipping the flag alone would accept unauthenticated POSTs. No
# other code path sends email; Supabase Auth handles signup/password-reset emails.
RESEND_API_KEY=your-resend-api-key
# EMAIL_WEBHOOK_ENABLED=false  # Re-enabling REQUIRES provider signature verification first (SPE-128)

# Cron Job Configuration
# Generate a secure token: openssl rand -base64 32
CRON_SECRET=your-long-random-secret-here

# Optional: Enable analytics cleanup (default: false)
# Set to 'true' to clean up analytics events older than 90 days
CLEANUP_ANALYTICS=false

# Monitoring (Optional)
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Environment
NODE_ENV=development